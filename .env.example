# Toàn bộ AI chạy trên máy local. Không dùng API key hay dịch vụ AI bên ngoài.
TRANSCRIPTION_PROVIDER=local
MAX_UPLOAD_MB=500
JOB_RETENTION_HOURS=24

# faster-whisper. Model được tải một lần vào runtime/models rồi suy luận offline.
LOCAL_ASR_MODEL=large-v3-turbo
LOCAL_ASR_DEVICE=cpu
LOCAL_ASR_COMPUTE_TYPE=int8
LOCAL_ASR_LANGUAGE=vi
LOCAL_MODEL_DIR=runtime/models
LOCAL_MODELS_ONLY=false

# Tóm tắt bằng Ollama local. URL bị giới hạn ở loopback trong code.
LOCAL_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_CONTEXT_TOKENS=32768

