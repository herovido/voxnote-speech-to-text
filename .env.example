# Toàn bộ AI chạy trên máy local. Không dùng API key hay dịch vụ AI bên ngoài.
TRANSCRIPTION_PROVIDER=local
MAX_UPLOAD_MB=500
# Job đã xong + file upload được tự dọn sau số giờ này (<=0 để tắt).
JOB_RETENTION_HOURS=24
# Số job được nhận đồng thời trước khi API trả 429.
MAX_ACTIVE_JOBS=10

# faster-whisper. Model được tải một lần vào runtime/models rồi suy luận offline.
# large-v3 (KHÔNG phải turbo): turbo bị cắt decoder 32->4 lớp, suy giảm rõ với
# ngôn ngữ ít dữ liệu (Khmer/Thai). Máy yếu có thể hạ xuống medium/small.
LOCAL_ASR_MODEL=large-v3
# GPU NVIDIA: LOCAL_ASR_DEVICE=cuda + LOCAL_ASR_COMPUTE_TYPE=float16
# (cài thêm requirements-gpu.txt trên Windows — DLL được tự nạp).
LOCAL_ASR_DEVICE=cpu
LOCAL_ASR_COMPUTE_TYPE=int8
# Để TRỐNG = tự nhận diện ngôn ngữ (vi/en/km/... 99 ngôn ngữ) rồi ghim cho cả file.
# Chỉ đặt cứng (vd "vi") khi chắc chắn mọi file cùng một ngôn ngữ.
LOCAL_ASR_LANGUAGE=
LOCAL_MODEL_DIR=runtime/models
LOCAL_MODELS_ONLY=false

# Routing per-ngôn ngữ: ngôn ngữ nhận diện được có model chuyên riêng thì dùng
# model đó cho cả file. Định dạng: lang=model[,lang=model...], model phải là
# định dạng CTranslate2 (repo HF hoặc đường dẫn local).
# Khmer đã verify thực nghiệm: large-v3 ra rác (confidence ~0.4) còn model dưới
# đây đúng gần từng chữ (confidence 0.99).
LOCAL_ASR_MODEL_OVERRIDES=km=PhanithLIM/whisper-tiny-khmer-ct2

# Tóm tắt bằng Ollama local. URL bị giới hạn ở loopback trong code.
LOCAL_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_CONTEXT_TOKENS=32768
